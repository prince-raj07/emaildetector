{
  "manifest_version": 3,
  "name": "PhishShield — AI Email Detector",
  "version": "1.1.0",
  "description": "Real-time AI-powered phishing detection using RAG + Agentic AI. Protect your inbox instantly.",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "PhishShield — Analyze Email"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://outlook.live.com/*",
        "https://outlook.office.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}